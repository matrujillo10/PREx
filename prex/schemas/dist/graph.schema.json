{
  "$defs": {
    "CallerStub": {
      "additionalProperties": false,
      "description": "Lightweight reference to an unchanged symbol that calls/imports a changed one.\n\nMaterialised in place of a full `SymbolNode` for symbols outside the changed\nfile set. Saves bytes; the host LLM can still attach an edge label without\nrendering the stub as if it were a peer of changed symbols.",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "caller_stub",
          "default": "caller_stub",
          "title": "Kind",
          "type": "string"
        },
        "qualified_name": {
          "title": "Qualified Name",
          "type": "string"
        },
        "file_id": {
          "description": "ID of the FileNode containing this caller.",
          "title": "File Id",
          "type": "string"
        },
        "symbol_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/SymbolKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "qualified_name",
        "file_id"
      ],
      "title": "CallerStub",
      "type": "object"
    },
    "ChangeState": {
      "description": "Diff overlay state of a graph node or edge.\n\nComputed by overlaying the unified diff on the symbol's line range;\n'added' means present at head_sha but not base_sha (or only on `+` lines).",
      "enum": [
        "unchanged",
        "added",
        "modified",
        "removed"
      ],
      "title": "ChangeState",
      "type": "string"
    },
    "Citation": {
      "additionalProperties": false,
      "description": "Universal provenance primitive.\n\nEvery prose field in PREx output (headlines, one-liners, plan rationales)\ncarries one or more `Citation` items. The host LLM is expected to render\na fact only via its citation; an unsourced claim is a validation error.",
      "properties": {
        "kind": {
          "description": "Resolution mode for `ref`: 'node' or 'edge' = id in graph.json; 'file_line' = '<path>#L<start>-L<end>' at pr.head_sha; 'external_doc' = absolute URL.",
          "enum": [
            "node",
            "edge",
            "file_line",
            "external_doc"
          ],
          "title": "Kind",
          "type": "string"
        },
        "ref": {
          "description": "Reference identifier. Format depends on `kind`.",
          "title": "Ref",
          "type": "string"
        },
        "excerpt": {
          "anyOf": [
            {
              "maxLength": 240,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional \u2264120-char literal quote of the cited evidence.",
          "title": "Excerpt"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "description": "How the claim being cited was produced."
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional 0..1 trust score for the claim. Use for visual weighting.",
          "title": "Score"
        }
      },
      "required": [
        "kind",
        "ref",
        "derivation"
      ],
      "title": "Citation",
      "type": "object"
    },
    "Derivation": {
      "description": "How a fact in the output was produced.\n\nMaps directly to a render tag the host LLM can show next to any claim.",
      "enum": [
        "ast",
        "diff",
        "crossref_text",
        "llm",
        "manifest",
        "heuristic"
      ],
      "title": "Derivation",
      "type": "string"
    },
    "Diagnostic": {
      "additionalProperties": false,
      "description": "Non-fatal warning emitted during graph or brief construction.\n\nUsed to surface static-analysis misses, ambiguity, schema invariant\nviolations, and LLM enrichment failures. Reviewer-visible at `level`\n>= 'warn'; `info` is plumbing.",
      "properties": {
        "level": {
          "description": "Severity.",
          "enum": [
            "info",
            "warn",
            "error"
          ],
          "title": "Level",
          "type": "string"
        },
        "code": {
          "description": "Stable identifier (e.g. 'INVARIANT_ORPHAN_EDGE').",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "related_node_ids": {
          "description": "Node IDs this diagnostic refers to. Empty for global diagnostics.",
          "items": {
            "type": "string"
          },
          "title": "Related Node Ids",
          "type": "array"
        }
      },
      "required": [
        "level",
        "code",
        "message"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "Edge": {
      "additionalProperties": false,
      "description": "Typed directed edge between two nodes.\n\nEach cross-file caller edge MUST carry at least one `Citation` (typically\na `file_line` reference to the call site). Other edges may carry zero.",
      "properties": {
        "id": {
          "description": "Globally unique edge id.",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/EdgeType"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "target_id": {
          "title": "Target Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How this edge was derived."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Edge-level diff overlay (added/removed/modified/unchanged)."
        },
        "cites": {
          "description": "Citations grounding this edge \u2014 usually file_line references to a call site.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-text annotation. Especially used for llm-derived reasoning.",
          "title": "Note"
        }
      },
      "required": [
        "id",
        "type",
        "source_id",
        "target_id"
      ],
      "title": "Edge",
      "type": "object"
    },
    "EdgeType": {
      "description": "Typed, directed edge.\n\nAllowed source/target kinds per type:\n    contains:    Module->File, File->Symbol, File->Hunk, File->CallerStub\n    defines:     Hunk->Symbol  (signature-affecting change)\n    touches:     Hunk->Symbol  (body-only change)\n    calls:       (Symbol|CallerStub)->Symbol\n    references:  (Symbol|CallerStub)->Symbol  (non-call: type usage / read)\n    imports:     File->(Symbol|Module|CallerStub)\n    covers:      Symbol(symbol_kind=test)->Symbol\n    external:    Symbol->ExternalRef",
      "enum": [
        "contains",
        "defines",
        "touches",
        "calls",
        "references",
        "imports",
        "covers",
        "external"
      ],
      "title": "EdgeType",
      "type": "string"
    },
    "ExternalRefKind": {
      "description": "Category of an external (out-of-repo) reference.",
      "enum": [
        "db_table",
        "http_route",
        "grpc_method",
        "package",
        "other"
      ],
      "title": "ExternalRefKind",
      "type": "string"
    },
    "ExternalRefNode": {
      "additionalProperties": false,
      "description": "A reference to a resource outside the codebase (DB table, HTTP route, etc.).",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "external_ref",
          "default": "external_ref",
          "title": "Kind",
          "type": "string"
        },
        "ref_kind": {
          "$ref": "#/$defs/ExternalRefKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        }
      },
      "required": [
        "id",
        "ref_kind",
        "name"
      ],
      "title": "ExternalRefNode",
      "type": "object"
    },
    "FileNode": {
      "additionalProperties": false,
      "description": "A source file at head_sha (or base_sha if removed).",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "file",
          "default": "file",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "language": {
          "description": "tree-sitter grammar name (e.g. 'python').",
          "title": "Language",
          "type": "string"
        },
        "generated": {
          "default": false,
          "description": "True if classified as generated/codegen. Collapse by default in UIs.",
          "title": "Generated",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "path",
        "language"
      ],
      "title": "FileNode",
      "type": "object"
    },
    "HunkChangeType": {
      "description": "Hunk-level diff direction.",
      "enum": [
        "added",
        "modified",
        "removed"
      ],
      "title": "HunkChangeType",
      "type": "string"
    },
    "HunkNode": {
      "additionalProperties": false,
      "description": "A contiguous diff region within one file. The atomic unit of change.",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "hunk",
          "default": "hunk",
          "title": "Kind",
          "type": "string"
        },
        "file_id": {
          "title": "File Id",
          "type": "string"
        },
        "line_range": {
          "$ref": "#/$defs/LineRange",
          "description": "Lines at head_sha (or base_sha if removed-only)."
        },
        "change_type": {
          "$ref": "#/$defs/HunkChangeType"
        },
        "patch": {
          "description": "Unified-diff fragment ('@@' header + body).",
          "title": "Patch",
          "type": "string"
        }
      },
      "required": [
        "id",
        "file_id",
        "line_range",
        "change_type",
        "patch"
      ],
      "title": "HunkNode",
      "type": "object"
    },
    "LineRange": {
      "additionalProperties": false,
      "description": "Inclusive 1-indexed line range in a file at a given SHA.",
      "properties": {
        "start": {
          "description": "1-indexed start line.",
          "minimum": 1,
          "title": "Start",
          "type": "integer"
        },
        "end": {
          "description": "1-indexed end line, inclusive of `start`.",
          "minimum": 1,
          "title": "End",
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "LineRange",
      "type": "object"
    },
    "ModuleNode": {
      "additionalProperties": false,
      "description": "A logical module \u2014 a directory containing source files belonging to one unit.",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "module",
          "default": "module",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "description": "Dotted/path-shaped module identifier.",
          "title": "Name",
          "type": "string"
        },
        "path": {
          "description": "Repo-relative directory path.",
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "path"
      ],
      "title": "ModuleNode",
      "type": "object"
    },
    "PRMetadata": {
      "additionalProperties": false,
      "description": "Identifying info for the PR the graph was built from.\n\nCaptures everything needed to reproduce the parse: repo, base/head SHAs,\nbranch names, plus surface metadata for UI display. The full PR `body`\nis preserved here so the briefing layer can extract author intent.",
      "properties": {
        "url": {
          "description": "Canonical PR URL.",
          "title": "Url",
          "type": "string"
        },
        "repo": {
          "description": "Owner/name slug.",
          "title": "Repo",
          "type": "string"
        },
        "number": {
          "minimum": 1,
          "title": "Number",
          "type": "integer"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "body": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Full PR body / description as fetched from the host. Used for intent extraction.",
          "title": "Body"
        },
        "author": {
          "title": "Author",
          "type": "string"
        },
        "base_ref": {
          "title": "Base Ref",
          "type": "string"
        },
        "head_ref": {
          "title": "Head Ref",
          "type": "string"
        },
        "base_sha": {
          "minLength": 7,
          "title": "Base Sha",
          "type": "string"
        },
        "head_sha": {
          "minLength": 7,
          "title": "Head Sha",
          "type": "string"
        },
        "additions": {
          "minimum": 0,
          "title": "Additions",
          "type": "integer"
        },
        "deletions": {
          "minimum": 0,
          "title": "Deletions",
          "type": "integer"
        },
        "changed_files": {
          "minimum": 0,
          "title": "Changed Files",
          "type": "integer"
        }
      },
      "required": [
        "url",
        "repo",
        "number",
        "title",
        "author",
        "base_ref",
        "head_ref",
        "base_sha",
        "head_sha",
        "additions",
        "deletions",
        "changed_files"
      ],
      "title": "PRMetadata",
      "type": "object"
    },
    "SymbolKind": {
      "description": "Sub-kind of a Symbol node.",
      "enum": [
        "function",
        "method",
        "class",
        "type",
        "const",
        "test"
      ],
      "title": "SymbolKind",
      "type": "string"
    },
    "SymbolNode": {
      "additionalProperties": false,
      "description": "A named, addressable definition: function, method, class, type, const, or test.",
      "properties": {
        "id": {
          "description": "Globally unique within this graph. Format: '<kind>:<stable-key>'.",
          "title": "Id",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/Derivation",
          "default": "ast",
          "description": "How the resolver derived this node's existence."
        },
        "score": {
          "default": 1.0,
          "description": "0..1 trust score. AST/diff sources default to 1.0; LLM-inferred is lower.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "change_state": {
          "$ref": "#/$defs/ChangeState",
          "default": "unchanged",
          "description": "Diff overlay state of this node."
        },
        "cites": {
          "description": "Optional citations supporting this node's existence/identity.",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Cites",
          "type": "array"
        },
        "kind": {
          "const": "symbol",
          "default": "symbol",
          "title": "Kind",
          "type": "string"
        },
        "symbol_kind": {
          "$ref": "#/$defs/SymbolKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "qualified_name": {
          "description": "Module-rooted dotted name (e.g. 'pkg.mod.Class.method').",
          "title": "Qualified Name",
          "type": "string"
        },
        "file_id": {
          "title": "File Id",
          "type": "string"
        },
        "line_range": {
          "$ref": "#/$defs/LineRange"
        },
        "signature": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "One-line signature if extractable.",
          "title": "Signature"
        },
        "public": {
          "default": false,
          "description": "Heuristic: not '_'-prefixed, in __all__, or referenced cross-module.",
          "title": "Public",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "symbol_kind",
        "name",
        "qualified_name",
        "file_id",
        "line_range"
      ],
      "title": "SymbolNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Complete impact graph for one PR. Versioned root document.",
  "properties": {
    "schema_version": {
      "const": "0.2.0",
      "default": "0.2.0",
      "description": "Semantic version. v0.2 dropped Confidence enum + added CallerStub.",
      "title": "Schema Version",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "generator": {
      "title": "Generator",
      "type": "string"
    },
    "pr": {
      "$ref": "#/$defs/PRMetadata"
    },
    "nodes": {
      "items": {
        "discriminator": {
          "mapping": {
            "caller_stub": "#/$defs/CallerStub",
            "external_ref": "#/$defs/ExternalRefNode",
            "file": "#/$defs/FileNode",
            "hunk": "#/$defs/HunkNode",
            "module": "#/$defs/ModuleNode",
            "symbol": "#/$defs/SymbolNode"
          },
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/ModuleNode"
          },
          {
            "$ref": "#/$defs/FileNode"
          },
          {
            "$ref": "#/$defs/SymbolNode"
          },
          {
            "$ref": "#/$defs/CallerStub"
          },
          {
            "$ref": "#/$defs/HunkNode"
          },
          {
            "$ref": "#/$defs/ExternalRefNode"
          }
        ]
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/Edge"
      },
      "title": "Edges",
      "type": "array"
    },
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/Diagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    }
  },
  "required": [
    "generated_at",
    "generator",
    "pr",
    "nodes",
    "edges"
  ],
  "title": "Graph",
  "type": "object"
}
